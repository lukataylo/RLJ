# RLJ voice stream configuration. Copy to `.env` and fill in what you have.
# EVERYTHING here is optional — with no keys at all the stream falls back to
# keyword NLU + console output and still runs the full demo loop.

# --- ElevenLabs (outbound calls / TTS). Leave blank to use the console fallback. ---
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM     # default "Rachel" voice for TTS
ELEVENLABS_AGENT_ID=                          # conversational-agent id (optional)

# --- Orchestrator (the hub we integrate through). ---
ORCHESTRATOR_URL=http://localhost:8000
# WebSocket is derived from ORCHESTRATOR_URL by default; override only if needed.
# ORCHESTRATOR_WS=ws://localhost:8000/ws

# --- Local LLM for NLU (OpenAI-compatible: Ollama / NemoClaw / inference.local). ---
# Leave LLM_BASE_URL blank to skip the model entirely and use the keyword fallback.
LLM_BASE_URL=http://localhost:11434/v1        # Ollama default; or http://inference.local/v1
LLM_MODEL=nemotron
LLM_API_KEY=ollama                            # most local servers ignore this; any value is fine
