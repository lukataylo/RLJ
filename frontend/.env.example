# PulseGo command-center frontend — two deploy modes. Copy to .env.local and
# uncomment ONE block. REST + WebSocket are derived from VITE_ORCHESTRATOR_URL.

# ── Production (pulsego.org) ───────────────────────────────────────────────
# Hosted API; no DGX/Valhalla, so routes draw via the client-side Mapbox API.
VITE_ORCHESTRATOR_URL=https://api.pulsego.org   # hosted orchestrator base URL
VITE_MAPBOX_TOKEN=                              # PUBLIC mapbox token ("pk."), required in prod for routes
VITE_LOCAL=false                               # "false" → default route source = mapbox

# ── Local (DGX / scan-11) ──────────────────────────────────────────────────
# DGX-hosted box serves offline Valhalla road geometry; no Mapbox token needed.
# VITE_ORCHESTRATOR_URL=http://scan-11.local:8000  # DGX host (or the box IP), :8000
# VITE_LOCAL=true                                  # "true" → default route source = valhalla
# VITE_MAPBOX_TOKEN=                               # optional locally (Valhalla is used)
