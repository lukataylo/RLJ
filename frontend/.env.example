# Base URL of the orchestrator (REST + WebSocket are derived from this).
# REST:  http://localhost:8000
# WS:    ws://localhost:8000/ws
VITE_ORCHESTRATOR_URL=http://localhost:8000

# Mapbox PUBLIC (publishable) token (starts with "pk."). Optional.
# When set, the map uses a premium Mapbox dark basemap (mapbox://styles/mapbox/dark-v11).
# When left empty, it gracefully falls back to the token-less MapLibre CARTO dark style.
VITE_MAPBOX_TOKEN=
