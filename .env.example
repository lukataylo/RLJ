# PulseGo backend environment — the SAME code runs in two modes, switched by LOCAL.
#
#   LOCAL=true   → developer / GB10 (DGX Spark) mode: route over the on-box Valhalla
#                  road graph and run the LLM on the box's Ollama/Nemotron.
#   LOCAL=false  → production (pulsego.org / Railway, NO DGX access): travel times fall
#                  back to the built-in haversine model, the UI draws routes via Mapbox,
#                  and the LLM (NL intake + agent answers) runs on OpenAI.
#
# Copy to `.env` and fill in. Frontend vars live in frontend/.env.example.
# ---------------------------------------------------------------------------------

# ===== deploy mode =====
LOCAL=false                       # "true" to use the DGX Spark backends below

# ===== DGX Spark backends (only used when LOCAL=true) =====
# The GB10 box hosts Valhalla (offline routing) + Ollama (Nemotron). Point these at
# the box — its mDNS host or LAN IP. When LOCAL=false these are ignored.
DGX_HOST=scan-11.local            # e.g. scan-11.local or 10.18.216.46
VALHALLA_URL=http://scan-11.local:8002    # Valhalla matrix + /route (routing service reads this)
OLLAMA=http://scan-11.local:11434         # Ollama OpenAI-less endpoint for Nemotron
MODEL=nemotron                            # Ollama model tag

# ===== LLM for production (used when LOCAL=false) =====
OPENAI_API_KEY=                   # required in prod for NL intake parsing + agent answers
OPENAI_MODEL=gpt-4o-mini          # any chat model that supports JSON response_format

# ===== services =====
ROUTING_URL=http://localhost:8100         # orchestrator -> routing service (private)
# Comma-separated browser origins allowed to call the API (frontends).
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,https://pulsego.org,https://app.pulsego.org

# ===== auth (off by default so existing tests/anon writes keep working) =====
AUTH_REQUIRED=false               # "true" in prod to require Bearer JWT on write endpoints
JWT_SECRET=                       # set a strong secret in prod (a dev default is used if empty)
ADMIN_EMAIL=                      # optional: seed an admin at startup
ADMIN_PASSWORD=
DATABASE_URL=                     # Postgres URL in prod; empty -> local SQLite (orchestrator/pulsego.db)
