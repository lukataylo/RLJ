# PulseGo orchestrator base URL (REST + WS derived from this).
# Default is production; override for local dev with your machine's LAN IP so a
# phone running Expo Go can reach it, e.g. http://192.168.1.20:8000
EXPO_PUBLIC_API_URL=https://api.pulsego.org

# One-tap local Nemotron / DGX box preset shown in Settings. Use your Mac/DGX LAN
# IP when testing on a physical phone, e.g. http://192.168.1.20:8000.
EXPO_PUBLIC_LOCAL_API_URL=http://localhost:8000

# Optional Mapbox token. When set, the Navigate tab fetches real street-name
# turn-by-turn maneuvers from the Mapbox Directions API. When absent, the app
# falls back to on-device maneuvers derived from the route polyline geometry.
EXPO_PUBLIC_MAPBOX_TOKEN=
